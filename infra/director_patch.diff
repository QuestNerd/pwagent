+def _ollama_chat_url(base_url: str) -> str:
+    return base_url.rstrip("/") + "/api/chat"
+
+def _format_messages(role_prompt: str, user_messages: List[Dict[str, Any]]) -> List[Dict[str, str]]:
+    # Ollama accepts OpenAI-style messages (role/content).
+    msgs: List[Dict[str, str]] = [
+        {"role": "system", "content": SYS_DIRECTOR},
+        {"role": "system", "content": role_prompt},
+    ]
+    for m in user_messages:
+        role = (m.get("role") or "").strip()
+        content = m.get("content")
+        if not role or content is None:
+            continue
+        msgs.append({"role": role, "content": str(content)})
+    return msgs
+
+async def _post_with_retries(client: httpx.AsyncClient, url: str, json_body: Dict[str, Any], tag: str) -> Dict[str, Any]:
+    # Simple, deterministic retry (network/timeouts/5xx)
+    last_err: Optional[Exception] = None
+    for attempt in range(1, 4):
+        try:
+            r = await client.post(url, json=json_body)
+            # If Ollama is still loading a model, it can 5xx; treat as retryable.
+            if 500 <= r.status_code < 600:
+                raise httpx.HTTPStatusError(f"{r.status_code} {r.text}", request=r.request, response=r)
+            r.raise_for_status()
+            return r.json()
+        except (httpx.TimeoutException, httpx.TransportError, httpx.HTTPStatusError) as e:
+            last_err = e
+            log(f"{tag} attempt {attempt}/3 failed: {e}")
+            if attempt < 3:
+                await asyncio.sleep(0.5 * attempt)
+    raise last_err or RuntimeError("unknown error")
+
+async def call_llm(
+    base_url: str,
+    model: str,
+    role_prompt: str,
+    user_messages: List[Dict[str, Any]],
+    temperature: float = 0.2,
+    tag: str = ""
+) -> str:
+    """
+    Robust internal LLM call.
+    - Uses Ollama native /api/chat (since your containers return 404 on /v1/chat/completions).
+    - Retries transient failures.
+    - Never returns empty content silently.
+    """
+    if tag:
+        log(tag)
+
+    msgs = _format_messages(role_prompt, user_messages)
+    payload = {
+        "model": model,
+        "messages": msgs,
+        "stream": False,
+        "options": {"temperature": float(temperature)},
+    }
+
+    url = _ollama_chat_url(base_url)
+    async with httpx.AsyncClient(timeout=TIMEOUT) as client:
+        try:
+            data = await _post_with_retries(client, url, payload, tag=tag or "LLM_CALL")
+            content = ((data.get("message") or {}).get("content") or "").strip()
+            if content:
+                return content
+            # If Ollama returns empty, surface the whole response (this prevents “blank director”).
+            return f"[LLM_RETURNED_EMPTY] model={model} base={base_url} raw={json.dumps(data, ensure_ascii=False)[:2000]}"
+        except Exception as e:
+            return f"[LLM_CALL_FAILED] model={model} base={base_url} err={repr(e)}"

